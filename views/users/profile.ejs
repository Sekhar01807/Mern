<% layout("/layouts/boilerplate") %>

<div class="row mt-4">
    <div class="col-12">
        <%- include("../includes/flash.ejs") %>
    </div>
    <div class="col-12 col-md-4 mb-4">
        <!-- Profile Info Card -->
        <div class="card shadow-sm border-0">
            <div class="card-body text-center">
                <div class="position-relative d-inline-block mb-3" style="cursor: pointer;" onclick="document.getElementById('profileImage').click();">
                    <% if(user.profileImage && user.profileImage.url && !user.profileImage.url.includes("dwy7q5x2g") && user.profileImage.url !== "") { %>
                        <img id="profile-preview" src="<%= user.profileImage.url %>" alt="Profile Image" class="rounded-circle img-thumbnail" style="width: 150px; height: 150px; object-fit: cover;">
                    <% } else { %>
                        <div id="profile-preview-fallback" class="rounded-circle img-thumbnail d-flex justify-content-center align-items-center bg-danger text-white mx-auto" style="width: 150px; height: 150px; font-size: 4rem;">
                            <%= user.username.charAt(0).toUpperCase() %>
                        </div>
                        <img id="profile-preview" src="" style="display:none; width: 150px; height: 150px; object-fit: cover;" class="rounded-circle img-thumbnail">
                    <% } %>
                    
                    <!-- Hover Edit Overlay -->
                    <div class="position-absolute top-0 start-0 w-100 h-100 rounded-circle d-flex justify-content-center align-items-center profile-overlay" style="background: rgba(0,0,0,0.4); opacity: 0; transition: 0.2s;">
                        <i class="fa-solid fa-camera text-white" style="font-size: 2rem;"></i>
                    </div>
                </div>
                <h4 class="card-title">@<%= user.username %></h4>
                <p class="mb-2"><span class="badge <%= user.role === 'Host' ? 'bg-danger' : 'bg-primary' %> rounded-pill px-3"><%= user.role || 'Traveler' %></span></p>
                <p class="text-muted small mb-3 px-3"><%= user.bio || 'No bio yet.' %></p>
                <div class="text-start px-3 small mb-3">
                    <p class="text-muted mb-1"><i class="fa-solid fa-envelope me-2"></i> <%= user.email %></p>
                    <p class="text-muted mb-1"><i class="fa-solid fa-location-dot me-2"></i> <%= user.country || 'Not specified' %></p>
                    <p class="text-muted mb-1"><i class="fa-solid fa-phone me-2"></i> <%= user.phoneNumber || 'Add phone' %></p>
                    <p class="text-muted mb-1"><i class="fa-solid fa-language me-2"></i> <%= user.languages || 'English' %></p>
                </div>
                
                <hr>
                
                <h5 class="mb-3 text-start">Edit Profile</h5>
                <form action="/profile?_method=PUT" method="POST" enctype="multipart/form-data" class="text-start needs-validation" novalidate>
                    <div class="mb-3">
                        <label for="username" class="form-label text-muted small fw-bold">Username</label>
                        <input type="text" class="form-control" id="username" name="username" value="<%= user.username %>" required>
                    </div>
                    <div class="mb-3">
                        <label for="role" class="form-label text-muted small fw-bold">Account Type</label>
                        <select class="form-select" id="role" name="role">
                            <option value="Traveler" <%= user.role === 'Traveler' ? 'selected' : '' %>>Traveler (Explore & Book)</option>
                            <option value="Host" <%= user.role === 'Host' ? 'selected' : '' %>>Host (List & Manage Hotels)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="bio" class="form-label text-muted small fw-bold">Bio</label>
                        <textarea class="form-control" id="bio" name="bio" rows="2" placeholder="Tell us about yourself..."><%= user.bio %></textarea>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label for="country" class="form-label text-muted small fw-bold">Country</label>
                            <input type="text" class="form-control" id="country" name="country" value="<%= user.country %>" required>
                        </div>
                        <div class="col-6">
                            <label for="phoneNumber" class="form-label text-muted small fw-bold">Phone</label>
                            <input type="text" class="form-control" id="phoneNumber" name="phoneNumber" value="<%= user.phoneNumber %>" placeholder="+123...">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="languages" class="form-label text-muted small fw-bold">Languages Spoken</label>
                        <input type="text" class="form-control" id="languages" name="languages" value="<%= user.languages %>" placeholder="e.g. English, Hindi">
                    </div>
                    <input type="file" id="profileImage" name="profileImage" accept=".png, .jpg, .jpeg, .webp, image/*" style="display: none;">
                    <button type="submit" class="btn btn-danger w-100 py-2 fw-bold">Save Changes</button>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-md-8">
        <!-- Tabs for Listings, Wishlist, and Bookings -->
        <ul class="nav nav-tabs mb-4" id="profileTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="bookings-tab" data-bs-toggle="tab" data-bs-target="#bookings-tab-pane" type="button" role="tab" aria-controls="bookings-tab-pane" aria-selected="true" style="color: crimson; font-weight: bold;">
                    My Bookings (<%= userBookings.length %>)
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="listings-tab" data-bs-toggle="tab" data-bs-target="#listings-tab-pane" type="button" role="tab" aria-controls="listings-tab-pane" aria-selected="false" style="color: #222;">
                    My Listings (<%= userListings.length %>)
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="wishlist-tab" data-bs-toggle="tab" data-bs-target="#wishlist-tab-pane" type="button" role="tab" aria-controls="wishlist-tab-pane" aria-selected="false" style="color: #222;">
                    My Wishlist (<%= user.wishlist.length %>)
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews-tab-pane" type="button" role="tab" aria-controls="reviews-tab-pane" aria-selected="false" style="color: #222;">
                    My Reviews (<%= reviewsWithListings.length %>)
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="messages-tab" data-bs-toggle="tab" data-bs-target="#messages-tab-pane" type="button" role="tab" aria-controls="messages-tab-pane" aria-selected="false" style="color: #222;">
                    Messages (<%= conversations.length %>)
                </button>
            </li>
        </ul>
        
        <div class="tab-content" id="profileTabsContent">
            <!-- Bookings Tab -->
            <div class="tab-pane fade show active" id="bookings-tab-pane" role="tabpanel" aria-labelledby="bookings-tab" tabindex="0">
                <% if(userBookings.length === 0) { %>
                    <div class="text-center mt-5 text-muted">
                        <i class="fa-solid fa-plane-arrival mb-3" style="font-size: 3rem; color: #ccc;"></i>
                        <h5>No upcoming trips.</h5>
                        <a href="/listings" class="btn btn-outline-danger mt-2">Find a place to stay</a>
                    </div>
                <% } else { %>
                    <div class="row row-cols-1 g-4">
                        <% for(let booking of userBookings) { %>
                            <div class="col">
                                <div class="card border-0 shadow-sm rounded-4 overflow-hidden d-flex flex-row">
                                    <img src="<%= booking.listing.image.url %>" style="width: 200px; height: 150px; object-fit: cover;">
                                    <div class="card-body p-4 d-flex flex-column justify-content-center">
                                        <div class="d-flex justify-content-between">
                                            <h5 class="fw-bold"><%= booking.listing.title %></h5>
                                            <span class="badge bg-success py-2 px-3">Paid</span>
                                        </div>
                                        <p class="text-muted mb-1"><i class="fa-solid fa-calendar-days me-2"></i><%= new Date(booking.checkIn).toLocaleDateString() %> — <%= new Date(booking.checkOut).toLocaleDateString() %></p>
                                        <p class="text-muted mb-0"><i class="fa-solid fa-users me-2"></i><%= booking.guests %> Guests</p>
                                        <div class="mt-2">
                                            <a href="/listings/<%= booking.listing._id %>" class="btn btn-sm btn-dark">View Listing</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>

            <!-- Listings Tab -->
            <div class="tab-pane fade" id="listings-tab-pane" role="tabpanel" aria-labelledby="listings-tab" tabindex="0">
                <% if(userListings.length === 0) { %>
                    <div class="text-center mt-5 text-muted">
                        <i class="fa-solid fa-house mb-3" style="font-size: 3rem; color: #ccc;"></i>
                        <h5>You haven't created any listings yet.</h5>
                        <a href="/listings/new" class="btn btn-outline-danger mt-2">Create New Listing</a>
                    </div>
                <% } else { %>
                    <div class="row row-cols-lg-2 row-cols-md-2 row-cols-sm-1">
                        <% for(let listing of userListings) { %>
                            <div class="card listing-card mb-4" style="border: 1px solid #ddd !important; border-radius: 1rem; overflow: hidden;">
                                <a href="/listings/<%= listing._id %>" class="listing-link">
                                    <img src="<%= listing.image.url %>" class="card-img-top" alt="image" style="height: 15rem; object-fit: cover;">
                                </a>
                                <div class="card-body p-3">
                                    <h5 class="card-title text-truncate"><%= listing.title %></h5>
                                    <p class="card-text text-muted mb-2"><i class="fa-solid fa-location-dot"></i> <%= listing.location %></p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="fw-bold">&#8377 <%= listing.price ? listing.price.toLocaleString() : "N/A" %></span>
                                        <div>
                                            <a href="/listings/<%= listing._id %>/edit" class="btn btn-sm btn-outline-dark"><i class="fa-solid fa-pen"></i></a>
                                            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline delete-listing-form">
                                                <button type="button" class="btn btn-sm btn-outline-danger delete-listing-btn"><i class="fa-solid fa-trash"></i></button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>
            
            <!-- Wishlist Tab -->
            <div class="tab-pane fade" id="wishlist-tab-pane" role="tabpanel" aria-labelledby="wishlist-tab" tabindex="0">
                <% if(user.wishlist.length === 0) { %>
                    <div class="text-center mt-5 text-muted">
                        <i class="fa-solid fa-heart mb-3" style="font-size: 3rem; color: #ccc;"></i>
                        <h5>Your wishlist is empty.</h5>
                        <a href="/listings" class="btn btn-outline-danger mt-2">Explore Listings</a>
                    </div>
                <% } else { %>
                    <div class="row row-cols-lg-2 row-cols-md-2 row-cols-sm-1">
                        <% for(let listing of user.wishlist) { %>
                            <div class="card listing-card mb-4" style="border: 1px solid #ddd !important; border-radius: 1rem; overflow: hidden; position: relative;">
                                <a href="/listings/<%= listing._id %>" class="listing-link">
                                    <img src="<%= listing.image.url %>" class="card-img-top" alt="image" style="height: 15rem; object-fit: cover;">
                                </a>
                                <form method="POST" action="/wishlist/<%= listing._id %>" class="wishlist-btn-form">
                                    <button type="submit" class="wishlist-btn" title="Remove from Wishlist">
                                        <i class="fa-solid fa-heart" style="color:crimson;"></i>
                                    </button>
                                </form>
                                <div class="card-body p-3">
                                    <h5 class="card-title text-truncate"><%= listing.title %></h5>
                                    <p class="card-text text-muted mb-2"><i class="fa-solid fa-location-dot"></i> <%= listing.location %></p>
                                    <span class="fw-bold">&#8377 <%= listing.price ? listing.price.toLocaleString() : "N/A" %></span>
                                </div>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>
            
            <!-- Reviews Tab -->
            <div class="tab-pane fade" id="reviews-tab-pane" role="tabpanel" aria-labelledby="reviews-tab" tabindex="0">
                <% if(reviewsWithListings.length === 0) { %>
                    <div class="text-center mt-5 text-muted">
                        <i class="fa-solid fa-star mb-3" style="font-size: 3rem; color: #ccc;"></i>
                        <h5>You haven't written any reviews yet.</h5>
                    </div>
                <% } else { %>
                    <div class="row row-cols-1 row-cols-md-2 g-4">
                        <% for(let item of reviewsWithListings) { %>
                            <div class="col">
                              <div class="review-airbnb-card">
                                <!-- Listing link -->
                                <a href="/listings/<%= item.listing._id %>" class="d-flex align-items-center mb-3 text-decoration-none" style="color: inherit;">
                                    <img src="<%= item.listing.image.url %>" class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                    <h6 class="mb-0 fw-bold text-truncate"><%= item.listing.title %></h6>
                                </a>
                                <!-- Stars + Date -->
                                <div class="d-flex align-items-center mb-2">
                                    <p class="starability-result m-0 me-2" style="transform: scale(0.55); transform-origin: left center;" data-rating="<%= item.review.rating %>"></p>
                                    <span class="text-muted" style="font-size: 0.8rem;"><%= item.review.createdAt ? new Date(item.review.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) : '' %></span>
                                </div>
                                <!-- Comment with Show more -->
                                <div class="review-text-container">
                                    <p class="review-text-short mb-1" style="line-height: 1.5; font-size: 0.95rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;"><%= item.review.comment %></p>
                                    <p class="review-text-full mb-1" style="line-height: 1.5; font-size: 0.95rem; display: none;"><%= item.review.comment %></p>
                                    <% if (item.review.comment && item.review.comment.length > 120) { %>
                                        <a href="javascript:void(0)" class="show-more-link fw-bold" style="color: #222; text-decoration: underline; font-size: 0.9rem;" onclick="toggleReview(this)">Show more</a>
                                    <% } %>
                                </div>
                              </div>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>

            <!-- Messages Tab -->
            <div class="tab-pane fade" id="messages-tab-pane" role="tabpanel" aria-labelledby="messages-tab" tabindex="0">
                <% if(conversations.length === 0) { %>
                    <div class="text-center mt-5 text-muted">
                        <i class="fa-solid fa-message mb-3" style="font-size: 3rem; color: #ccc;"></i>
                        <h5>No messages yet.</h5>
                        <p>Questions about a stay? Reach out to the host!</p>
                    </div>
                <% } else { %>
                    <div class="row row-cols-1 g-3">
                        <% for(let convo of conversations) { %>
                            <div class="col">
                                <a href="/messages?receiverId=<%= convo.otherUser._id %>&listingId=<%= convo.listing._id %>" class="text-decoration-none text-dark">
                                    <div class="card border-0 shadow-sm rounded-4 p-3" style="background: #fff; transition: 0.3s; border: 1px solid #eee !important;">
                                        <div class="d-flex align-items-center">
                                            <div class="position-relative me-3">
                                                <% if(convo.otherUser.profileImage && convo.otherUser.profileImage.url) { %>
                                                    <img src="<%= convo.otherUser.profileImage.url %>" class="rounded-circle" style="width: 50px; height: 50px; object-fit: cover; border: 2px solid #ff385c;">
                                                <% } else { %>
                                                    <div class="rounded-circle bg-danger text-white d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; font-weight: bold;">
                                                        <%= convo.otherUser.username.charAt(0).toUpperCase() %>
                                                    </div>
                                                <% } %>
                                            </div>
                                            <div class="flex-grow-1 overflow-hidden">
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <h6 class="fw-bold mb-0">@<%= convo.otherUser.username %></h6>
                                                    <small class="text-muted"><%= new Date(convo.lastMessage.createdAt).toLocaleDateString() %></small>
                                                </div>
                                                <p class="mb-1 text-muted small text-truncate"><%= convo.lastMessage.content %></p>
                                                <small class="text-danger fw-bold" style="font-size: 0.7rem;"><i class="fa-solid fa-house me-1"></i> <%= convo.listing.title %></small>
                                            </div>
                                            <div class="ms-3">
                                                <i class="fa-solid fa-chevron-right text-muted small"></i>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script>
// Keep nav tab colors updated on click
document.querySelectorAll('#profileTabs .nav-link').forEach(tab => {
    tab.addEventListener('show.bs.tab', function (e) {
        document.querySelectorAll('#profileTabs .nav-link').forEach(t => {
            t.style.color = '#222';
            t.style.fontWeight = 'normal';
        });
        e.target.style.color = 'crimson';
        e.target.style.fontWeight = 'bold';
    });
});

// Setup Cropper for Profile Image (Aspect ratio 1:1)
document.addEventListener("DOMContentLoaded", () => {
    if (typeof setupImageCropper === 'function') {
        setupImageCropper('profileImage', 'profile-preview', 1);
    }
});

// Overlay Hover Effect
const profileContainer = document.querySelector('.position-relative.d-inline-block.mb-3');
const profileOverlay = document.querySelector('.profile-overlay');
profileContainer.addEventListener('mouseover', () => { profileOverlay.style.opacity = '1'; });
profileContainer.addEventListener('mouseout', () => { profileOverlay.style.opacity = '0'; });

// Show more / Show less for reviews
function toggleReview(link) {
    const container = link.closest('.review-text-container');
    const short = container.querySelector('.review-text-short');
    const full = container.querySelector('.review-text-full');
    if (short.style.display !== 'none') {
        short.style.display = 'none';
        full.style.display = 'block';
        link.textContent = 'Show less';
    } else {
        short.style.display = '-webkit-box';
        full.style.display = 'none';
        link.textContent = 'Show more';
    }
}
    // Delete Listing Confirmation (SweetAlert2)
    document.querySelectorAll('.delete-listing-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const result = await Swal.fire({
                title: 'Delete this Listing?',
                text: "This will permanently remove your hotel from WanderLust. You cannot undo this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ff385c',
                cancelButtonColor: '#222',
                confirmButtonText: 'Yes, delete it',
                background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#1e1e1e' : '#fff',
                color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#fff' : '#222',
                customClass: {
                    popup: 'rounded-4 border-0 shadow-lg',
                    confirmButton: 'rounded-pill px-4',
                    cancelButton: 'rounded-pill px-4'
                }
            });

            if (result.isConfirmed) {
                btn.closest('form').submit();
            }
        });
    });
</script>
