<% layout("/layouts/boilerplate") %>

<div class="row mt-5 mb-5">
    <div class="col-12 col-md-6 offset-md-3">
        <%- include("../includes/flash.ejs") %>
        <div class="card shadow border-0 rounded-4">
            <div class="card-body p-4 p-md-5">
                <h2 class="mb-4 fw-bold text-center" style="color: #ff385c;"><i class="fa-solid fa-right-to-bracket me-2"></i>Welcome Back</h2>
                <form action="/login" method="POST" id="loginForm" novalidate>
    <div class="mb-3">  
        <label for="username" class="form-label"> Username</label>
        <input type="text" name="username" id="username" class="form-control" required> 
        <div class="invalid-feedback"> Username Required ! </div>
    </div>
     <div class="mb-3">  
        <label for="password" class="form-label"> Password </label>
        <input type="password" name="password" id="password" class="form-control" required>
        <div class="invalid-feedback"> Password Required ! </div> 
    </div>
                    <button class="btn btn-danger w-100 py-2 fs-5 fw-bold rounded-3 mt-3" style="background-color: #ff385c; border: none; transition: 0.2s;">
                        Login
                    </button>
                </form>
                <hr class="my-4">
                <p class="text-center mb-0">Don't have an account? <a href="/signup" class="fw-bold" style="color: #ff385c; text-decoration: none;">Sign Up</a></p>
                <p class="text-center mt-2 mb-0"><a href="/forgot" class="small text-muted">Forgot Password?</a></p>
            </div>
        </div>
    </div>
</div>

<script>
(() => {
  const form = document.getElementById('loginForm');
  const inputs = form.querySelectorAll('input[required]');

  // While typing, show red border if empty, neutral if filled (never green)
  inputs.forEach(input => {
    input.addEventListener('input', () => {
      if (input.value.trim() === '') {
        input.classList.add('is-invalid');
      } else {
        input.classList.remove('is-invalid');
        // Remove is-valid so it does NOT turn green
        input.classList.remove('is-valid');
      }
    });
  });

  // On submit, validate — show red for empty fields
  form.addEventListener('submit', (e) => {
    let hasError = false;
    inputs.forEach(input => {
      if (!input.value.trim()) {
        input.classList.add('is-invalid');
        hasError = true;
      }
    });
    if (hasError) {
      e.preventDefault();
      e.stopPropagation();
    }
    // If no empty fields, form submits to server for actual auth check
  });
})();
</script>