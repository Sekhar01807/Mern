<% layout("/layouts/boilerplate") %>
<div class="row mt-5 animate__animated animate__fadeIn">
    <div class="col-md-8 offset-md-2 text-center py-5">
        <div class="error-container p-5 rounded-5 shadow-lg position-relative overflow-hidden" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.3);">
            <!-- Decorative Background Element -->
            <div class="position-absolute top-0 start-0 w-100 h-100" style="background: radial-gradient(circle at top right, rgba(255, 56, 92, 0.05), transparent); z-index: -1;"></div>
            
            <div class="mb-4">
                <i class="fa-solid fa-compass fa-spin-slow mb-4" style="font-size: 5rem; color: #ff385c; --fa-animation-duration: 10s;"></i>
                <h1 class="display-4 fw-bold mb-2" style="letter-spacing: -1px;">Oops! You're Lost.</h1>
                <p class="fs-5 text-muted mb-4">Even the best travelers take a wrong turn sometimes.</p>
            </div>

            <div class="alert alert-danger border-0 rounded-4 p-4 mb-5 shadow-sm" style="background: #fff5f6;">
                <div class="d-flex align-items-center justify-content-center mb-2">
                    <i class="fa-solid fa-circle-exclamation me-2 text-danger"></i>
                    <h6 class="mb-0 fw-bold text-danger">System Message</h6>
                </div>
                <p class="mb-0 text-dark font-monospace small"><%= message %></p>
            </div>

            <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                <a href="/listings" class="btn btn-danger btn-lg px-5 py-3 fw-bold rounded-pill shadow-sm" style="background: linear-gradient(135deg, #ff385c, #e03150); border: none;">
                    <i class="fa-solid fa-house-chimney me-2"></i>Back to Exploring
                </a>
                <button onclick="window.history.back()" class="btn btn-outline-dark btn-lg px-5 py-3 fw-bold rounded-pill">
                    <i class="fa-solid fa-arrow-left me-2"></i>Go Back
                </button>
            </div>

            <div class="mt-5 pt-4 border-top">
                <p class="text-muted small mb-0">Need help? <a href="mailto:support@wanderlust.com" class="text-danger text-decoration-none fw-bold">Contact our Concierge</a></p>
            </div>
        </div>
    </div>
</div>

<style>
    .fa-spin-slow {
        animation: fa-spin 20s infinite linear;
    }
    @keyframes fa-spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    .error-container {
        transition: transform 0.3s ease;
    }
    .error-container:hover {
        transform: translateY(-5px);
    }
</style>
