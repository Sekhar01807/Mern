<% layout("/layouts/boilerplate") %>

<div class="container mt-5 mb-5">
    <div class="row">
        <!-- Sidebar: Conversation List -->
        <div class="col-md-4 border-end">
            <div class="d-flex align-items-center mb-4">
                <i class="fa-solid fa-inbox fs-3 me-3 text-danger"></i>
                <h3 class="fw-bold mb-0">Messages</h3>
            </div>
            
            <div class="list-group list-group-flush shadow-sm rounded-4 overflow-hidden" id="conversationList" style="max-height: 600px; overflow-y: auto;">
                <div class="p-4 text-center text-muted">
                    <div class="spinner-border text-danger mb-2" role="status"></div>
                    <p>Loading conversations...</p>
                </div>
            </div>
        </div>

        <!-- Main: Chat Window -->
        <div class="col-md-8">
            <div id="chatPlaceholder" class="h-100 d-flex flex-column align-items-center justify-content-center text-muted py-5 rounded-4 bg-light">
                <i class="fa-regular fa-comments mb-3" style="font-size: 5rem; opacity: 0.2;"></i>
                <h4>Select a conversation to start chatting</h4>
                <p>All your property inquiries in one place</p>
            </div>

            <div id="activeChatWindow" class="d-none h-100 d-flex flex-column">
                <!-- Chat Header -->
                <div class="p-3 border-bottom d-flex align-items-center bg-white rounded-top-4 shadow-sm" style="z-index: 5;">
                    <div id="userProfileArea" class="d-flex align-items-center flex-grow-1">
                        <div id="activeUserInitial" class="rounded-circle bg-danger text-white d-flex justify-content-center align-items-center me-3" style="width: 45px; height: 45px; font-weight: bold; font-size: 1.2rem;"></div>
                        <div>
                            <h5 id="activeUserName" class="fw-bold mb-0">Select User</h5>
                            <small class="text-success"><i class="fa-solid fa-circle" style="font-size: 0.5rem;"></i> Online</small>
                        </div>
                    </div>
                    <button id="deleteConvoBtn" class="btn btn-outline-danger btn-sm rounded-pill px-3 shadow-sm border-0" title="Delete Conversation">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>
                </div>

                <!-- Messages -->
                <div id="messagesDisplay" class="flex-grow-1 p-4 bg-white border-start border-end" style="height: 450px; overflow-y: auto; background-image: url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png'); background-repeat: repeat; background-opacity: 0.05;">
                    <!-- Messages will load here -->
                </div>

                <!-- Input Area -->
                <div class="p-3 bg-white border rounded-bottom-4 shadow-sm">
                    <form id="inboxChatForm" class="d-flex gap-2">
                        <input type="text" id="inboxChatInput" class="form-control rounded-pill border px-4" style="background: #f8f9fa;" placeholder="Type a message..." required autocomplete="off">
                        <button type="submit" class="btn btn-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                            <i class="fa-solid fa-paper-plane"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const convoList = document.getElementById('conversationList');
    const chatPlaceholder = document.getElementById('chatPlaceholder');
    const activeChatWindow = document.getElementById('activeChatWindow');
    const messagesDisplay = document.getElementById('messagesDisplay');
    const inboxChatForm = document.getElementById('inboxChatForm');
    const inboxChatInput = document.getElementById('inboxChatInput');
    
    let currentReceiverId = null;
    let currentListingId = null;
    const currUserId = "<%= currUser ? currUser._id : '' %>";

    async function loadConversations() {
        try {
            const res = await fetch('/messages/inbox-data');
            const convos = await res.json();
            
            if (!convos || convos.length === 0) {
                convoList.innerHTML = '<div class="p-4 text-center text-muted">No messages yet.</div>';
                return;
            }

            convoList.innerHTML = '';
            convos.forEach(convo => {
                // Determine who the other person is
                const otherUser = convo.sender._id === currUserId ? convo.receiver : convo.sender;
                if (!otherUser) return;

                const item = document.createElement('a');
                item.href = 'javascript:void(0)';
                item.className = 'list-group-item list-group-item-action border-0 p-3 mb-2 rounded-4 d-flex align-items-center shadow-sm';
                
                const initial = otherUser.username ? otherUser.username.charAt(0).toUpperCase() : '?';
                const profileHtml = otherUser.profileImage?.url 
                    ? `<img src="${otherUser.profileImage.url}" class="rounded-circle me-3" style="width: 45px; height: 45px; object-fit: cover; border: 2px solid #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">`
                    : `<div class="rounded-circle bg-danger text-white d-flex justify-content-center align-items-center me-3" style="width: 45px; height: 45px; font-weight: bold; border: 2px solid #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">${initial}</div>`;

                item.innerHTML = `
                    ${profileHtml}
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="fw-bold mb-0 text-truncate" style="max-width: 120px;">${otherUser.username}</h6>
                            <small class="text-muted" style="font-size: 0.7rem;">${new Date(convo.createdAt).toLocaleDateString()}</small>
                        </div>
                        <p class="mb-0 text-muted small text-truncate">${convo.listing?.title || 'WanderLust Trip'}</p>
                    </div>
                `;
                
                item.onclick = () => selectConversation(otherUser, convo.listing?._id);
                convoList.appendChild(item);
            });
        } catch (err) {
            console.error(err);
            convoList.innerHTML = '<div class="p-4 text-center text-danger">Error loading inbox.</div>';
        }
    }

    async function selectConversation(user, listingId) {
        currentReceiverId = user._id;
        currentListingId = listingId;

        // Update Header
        document.getElementById('activeUserName').innerText = user.username;
        const initial = document.getElementById('activeUserInitial');
        initial.innerText = user.username ? user.username.charAt(0).toUpperCase() : '?';

        chatPlaceholder.classList.add('d-none');
        activeChatWindow.classList.remove('d-none');
        
        loadMessages();
    }

    async function loadMessages() {
        if (!currentReceiverId) return;
        try {
            const res = await fetch(`/messages/${currentReceiverId}?listingId=${currentListingId}`);
            const messages = await res.json();
            
            messagesDisplay.innerHTML = '';
            messages.forEach(msg => {
                const isMe = msg.sender._id === currUserId;
                const div = document.createElement('div');
                div.className = `d-flex ${isMe ? 'justify-content-end' : 'justify-content-start'} mb-3`;
                div.innerHTML = `
                    <div class="p-3 rounded-4 shadow-sm" style="max-width: 80%; background: ${isMe ? 'linear-gradient(135deg, #ff385c, #e03150)' : '#fff'}; color: ${isMe ? '#fff' : '#222'}; border: ${isMe ? 'none' : '1px solid #eee'};">
                        <p class="mb-0">${msg.content}</p>
                        <small class="opacity-50 mt-1 d-block text-end" style="font-size: 0.65rem;">${new Date(msg.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</small>
                    </div>
                `;
                messagesDisplay.appendChild(div);
            });
            messagesDisplay.scrollTop = messagesDisplay.scrollHeight;
        } catch (err) {
            console.error(err);
        }
    }

    inboxChatForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const content = inboxChatInput.value.trim();
        if (!content || !currentReceiverId) return;

        try {
            const res = await fetch('/messages', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    receiverId: currentReceiverId, 
                    listingId: currentListingId, 
                    content: content 
                })
            });

            if (res.ok) {
                inboxChatInput.value = '';
                await loadMessages();
            }
        } catch (err) {
            console.error(err);
        }
    });

    const deleteConvoBtn = document.getElementById('deleteConvoBtn');
    deleteConvoBtn.addEventListener('click', async () => {
        if (!currentReceiverId) return;

        const result = await Swal.fire({
            title: 'Delete Conversation?',
            text: "All messages in this chat will be permanently removed. This cannot be undone!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ff385c',
            cancelButtonColor: '#222',
            confirmButtonText: 'Yes, delete it!',
            background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#1e1e1e' : '#fff',
            color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#fff' : '#222',
            customClass: {
                popup: 'rounded-4 border-0 shadow-lg',
                confirmButton: 'rounded-pill px-4',
                cancelButton: 'rounded-pill px-4'
            }
        });

        if (result.isConfirmed) {
            try {
                const res = await fetch(`/messages/${currentReceiverId}?listingId=${currentListingId}`, {
                    method: 'DELETE'
                });
                if (res.ok) {
                    Swal.fire({
                        title: 'Deleted!',
                        text: 'Your conversation has been wiped.',
                        icon: 'success',
                        confirmButtonColor: '#ff385c',
                        timer: 2000
                    });
                    activeChatWindow.classList.add('d-none');
                    chatPlaceholder.classList.remove('d-none');
                    loadConversations();
                }
            } catch (err) {
                console.error(err);
                Swal.fire('Error', 'Failed to delete conversation.', 'error');
            }
        }
    });

    loadConversations().then(() => {
        // Auto-select if URL has params
        const urlParams = new URLSearchParams(window.location.search);
        const rId = urlParams.get('receiverId');
        const lId = urlParams.get('listingId');
        if (rId) {
            // Find user in conversation data or fetch minimally
            // For now, we can just call selectConversation if we have the data
            // But selectConversation needs a 'user' object. 
            // We'll add a small helper to fetch user name or just let it load when clicked.
            // Better: Trigger a click on the correct item in convoList
            const items = convoList.querySelectorAll('a');
            items.forEach(item => {
                // This is a bit hacky but works if the user is in the list
                // To be robust, we'll just call selectConversation with a minimal object
                // if we don't find it.
            });
            
            // Re-fetching the specific user for the header
            selectConversation({ _id: rId, username: 'Loading...' }, lId);
        }
    });

    setInterval(() => {
        if (!activeChatWindow.classList.contains('d-none')) {
            loadMessages();
        }
    }, 3000);
});
</script>
