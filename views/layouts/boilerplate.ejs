<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"
        integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap');
    </style>
    <link href="/css/rating.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" rel="stylesheet" />
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const getPreferredTheme = () => {
            const storedTheme = localStorage.getItem('theme');
            if (storedTheme) {
                return storedTheme;
            }
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        };
        document.documentElement.setAttribute('data-bs-theme', getPreferredTheme());
    </script>
</head>

<body>
    <%- include("../includes/navbar.ejs") %>

        <div class="container">
                <%- body %>
        </div>

        <%- include("../includes/footer.ejs") %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
                integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
                crossorigin="anonymous">
                </script>

            <script src="/js/script.js"></script>
            <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
            <script src="/js/cropper-setup.js"></script>

            <!-- Global Cropper Modal -->
            <div class="modal fade" id="cropperModal" tabindex="-1" aria-labelledby="cropperModalLabel" aria-hidden="true" data-bs-backdrop="static">
              <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title" id="cropperModalLabel">Adjust Image</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                  </div>
                  <div class="modal-body p-3 bg-dark">
                    <div class="img-container" style="width: 100%; max-height: 60vh; text-align: center;">
                      <img id="imageToCrop" src="" style="max-width: 100%; max-height: 60vh; display: block; margin: 0 auto;">
                    </div>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="cropImageBtn">Apply Crop</button>
                  </div>
                </div>
              </div>
            </div>
    <!-- Global Notification System -->
    <script>
    (function initNotifications() {
        const currUser = <%= (typeof currUser !== 'undefined' && currUser) ? 'true' : 'false' %>;
        if (!currUser) return;

        const checkAlerts = async () => {
            try {
                const res = await fetch('/notifications/summary');
                const data = await res.json();
                if (data.success && data.alerts.length > 0) {
                    data.alerts.forEach(alert => {
                        const alertKey = `alert_${alert.type}_${alert.listingId}_${alert.days || alert.senderId}`;
                        if (!sessionStorage.getItem(alertKey)) {
                            Swal.fire({
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 6000,
                                timerProgressBar: true,
                                icon: alert.type === 'booking' ? 'info' : 'success',
                                title: alert.type === 'booking' ? 'Upcoming Trip!' : 'New Message',
                                text: alert.message,
                                background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#1e1e1e' : '#fff',
                                color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#fff' : '#222',
                                customClass: {
                                    popup: 'rounded-4 border-0 shadow-lg',
                                },
                                didOpen: (toast) => {
                                    toast.style.cursor = 'pointer';
                                    toast.addEventListener('click', () => {
                                        if (alert.type === 'message') {
                                            window.location.href = `/messages?receiverId=${alert.senderId}&listingId=${alert.listingId}`;
                                        } else {
                                            window.location.href = '/profile';
                                        }
                                    });
                                }
                            });
                            sessionStorage.setItem(alertKey, 'shown');
                        }
                    });
                }
            } catch (err) {
                console.error("Notification check failed", err);
            }
        };

        checkAlerts();
        setInterval(checkAlerts, 120000); // Check every 2 minutes
    })();
    </script>
</body>

</html>