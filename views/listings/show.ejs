      <div class="col-12 mb-5">
        <h4 class="fw-bold mb-4"><i class="fa-solid fa-map-location-dot me-2" style="color: #ff385c;"></i>Where you'll be</h4>
        <div id="map" class="rounded-4 shadow-sm border" style="height: 400px; width: 100%; z-index: 1; background-color: #eee;"></div>
        <p class="text-muted mt-3 fw-bold"><i class="fa-solid fa-location-crosshairs me-2"></i><%= listing.location %>, <%= listing.country %></p>
      </div>

    </div>
  </div>

  <!-- Mapbox & Leaflet Assets -->
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.1.2/mapbox-gl.css" rel="stylesheet">
  <script src="https://api.mapbox.com/mapbox-gl-js/v3.1.2/mapbox-gl.js"></script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <script>
    (function initUniversalMap() {
        const mapContainer = document.getElementById('map');
        const mapToken = "<%= mapToken %>";
        const listing = <%- JSON.stringify(listing) %>;
        
        let coords = [78.4867, 17.3850]; // Fallback coordinates
        if (listing.geometry && listing.geometry.coordinates && listing.geometry.coordinates.length === 2) {
            coords = listing.geometry.coordinates;
        }

        const latLon = [coords[1], coords[0]];

        // Attempt Mapbox first
        try {
            mapboxgl.accessToken = mapToken;
            const mapbox = new mapboxgl.Map({
                container: 'map',
                style: 'mapbox://styles/mapbox/streets-v12',
                center: coords,
                zoom: 10
            });

            mapbox.on('error', (e) => {
                console.warn("Mapbox failed to load tiles, switching to Leaflet fallback...");
                loadLeafletFallback();
            });

            new mapboxgl.Marker({ color: "#ff385c" })
                .setLngLat(coords)
                .setPopup(new mapboxgl.Popup({ offset: 25 }).setHTML(`<h6>${listing.title}</h6>`))
                .addTo(mapbox);

        } catch (e) {
            console.error("Mapbox init failed, using Leaflet:", e);
            loadLeafletFallback();
        }

        function loadLeafletFallback() {
            mapContainer.innerHTML = ""; // Clear any partial Mapbox junk
            const map = L.map('map').setView(latLon, 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);
            L.marker(latLon).addTo(map)
                .bindPopup("<h6><%= listing.title %></h6>")
                .openPopup();
            
            setTimeout(() => { map.invalidateSize(); }, 500);
        }
    })();
  </script>



<script>
// Booking Calculator
(() => {
    const checkinInput = document.getElementById('checkin');
    const checkoutInput = document.getElementById('checkout');
    const totalDisplay = document.getElementById('bookingTotal');
    const bookBtn = document.getElementById('bookNowBtn');
    const pricePerNight = <%= listing.price || 0 %>;

    // Set min date to today
    const today = new Date().toISOString().split('T')[0];
    if (checkinInput) checkinInput.min = today;
    if (checkoutInput) checkoutInput.min = today;

    function calcTotal() {
        if (!checkinInput || !checkoutInput) return;
        const checkin = new Date(checkinInput.value);
        const checkout = new Date(checkoutInput.value);
        const guestInput = document.getElementById('guests');
        const guests = guestInput ? parseInt(guestInput.value) : 1;

        if (checkinInput.value && checkoutInput.value && checkout > checkin) {
            const nights = Math.ceil((checkout - checkin) / (1000 * 60 * 60 * 24));
            
            // 25% extra for each guest after the first one
            const extraCharge = guests > 1 ? (guests - 1) * 0.25 * pricePerNight : 0;
            const total = nights * (pricePerNight + extraCharge);
            
            totalDisplay.innerHTML = `&#8377; ${total.toLocaleString('en-IN')} <span class="fs-6 fw-normal text-muted">(${nights} night${nights > 1 ? 's' : ''})</span>`;
        } else {
            totalDisplay.innerHTML = `&#8377; ${pricePerNight.toLocaleString('en-IN')}`;
        }
    }

    if (checkinInput) {
        checkinInput.addEventListener('change', () => {
            // Auto-set checkout min to day after checkin
            const nextDay = new Date(checkinInput.value);
            nextDay.setDate(nextDay.getDate() + 1);
            checkoutInput.min = nextDay.toISOString().split('T')[0];
            if (checkoutInput.value && new Date(checkoutInput.value) <= new Date(checkinInput.value)) {
                checkoutInput.value = nextDay.toISOString().split('T')[0];
            }
            calcTotal();
        });
    }
    if (checkoutInput) checkoutInput.addEventListener('change', calcTotal);
    
    // Add event listener for guest count changes
    const guestInput = document.getElementById('guests');
    if (guestInput) {
        guestInput.addEventListener('change', calcTotal);
    }

    if (bookBtn) {
        // Toggle Logic for Rescheduling
        const rescheduleBtn = document.getElementById('rescheduleBtn');
        const cancelRescheduleBtn = document.getElementById('cancelRescheduleBtn');
        const bookingStatusCard = document.getElementById('bookingStatusCard');
        const rescheduleUI = document.getElementById('rescheduleUI');

        if (rescheduleBtn) {
            rescheduleBtn.addEventListener('click', () => {
                bookingStatusCard.style.display = 'none';
                rescheduleUI.style.display = 'block';
                checkinInput.focus();
            });
        }

        if (cancelRescheduleBtn) {
            cancelRescheduleBtn.addEventListener('click', () => {
                rescheduleUI.style.display = 'none';
                bookingStatusCard.style.display = 'block';
            });
        }

        bookBtn.addEventListener('mouseenter', () => {
            bookBtn.style.transform = 'scale(1.02)';
            bookBtn.style.boxShadow = '0 8px 20px rgba(255,56,92,0.4)';
        });
        bookBtn.addEventListener('mouseleave', () => {
            bookBtn.style.transform = 'scale(1)';
            bookBtn.style.boxShadow = 'none';
        });
        // Common click handler for both buttons
        const handleBookingSubmit = (btnType) => {
            const isUserLoggedIn = <%= (typeof currUser !== 'undefined' && currUser) ? 'true' : 'false' %>;
            
            if (!isUserLoggedIn) {
                window.location.href = `/listings/<%= listing._id %>/reserve`;
                return false;
            }

            if (!checkinInput.value || !checkoutInput.value) {
                const toast = document.createElement('div');
                toast.className = 'position-fixed bottom-0 end-0 p-3';
                toast.style.zIndex = '1100';
                toast.innerHTML = `<div class="toast show align-items-center text-white bg-danger border-0" role="alert"><div class="d-flex"><div class="toast-body">Please select check-in and check-out dates!</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>`;
                document.body.appendChild(toast);
                setTimeout(() => toast.remove(), 3000);
                return false;
            }
            
            if (btnType === 'reschedule') {
                document.getElementById('hiddenRescheduleCheckin').value = checkinInput.value;
                document.getElementById('hiddenRescheduleCheckout').value = checkoutInput.value;
                document.getElementById('hiddenRescheduleGuests').value = document.getElementById('guests').value;
            } else {
                document.getElementById('hiddenCheckin').value = checkinInput.value;
                document.getElementById('hiddenCheckout').value = checkoutInput.value;
                document.getElementById('hiddenGuests').value = document.getElementById('guests').value;
            }
            return true;
        };

        if (bookBtn) {
            bookBtn.closest('form').addEventListener('submit', (e) => {
                if (!handleBookingSubmit('new')) e.preventDefault();
            });
        }

        const rescheduleConfirmBtn = document.getElementById('rescheduleConfirmBtn');
        if (rescheduleConfirmBtn) {
            rescheduleConfirmBtn.closest('form').addEventListener('submit', (e) => {
                if (!handleBookingSubmit('reschedule')) e.preventDefault();
            });
        }
    }
    
    const cancelTripBtn = document.getElementById('cancelTripBtn');
    if (cancelTripBtn) {
        cancelTripBtn.addEventListener('click', async (e) => {
            e.preventDefault();
            const result = await Swal.fire({
                title: 'Cancel your trip?',
                text: "Are you sure you want to cancel this reservation? This cannot be undone.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ff385c',
                cancelButtonColor: '#222',
                confirmButtonText: 'Yes, cancel it',
                background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#1e1e1e' : '#fff',
                color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#fff' : '#222',
                customClass: {
                    popup: 'rounded-4 border-0 shadow-lg',
                    confirmButton: 'rounded-pill px-4',
                    cancelButton: 'rounded-pill px-4'
                }
            });

            if (result.isConfirmed) {
                cancelTripBtn.closest('form').submit();
            }
        });
    }

    // Delete Listing Confirmation
    const deleteListingBtn = document.getElementById('deleteListingBtn');
    if (deleteListingBtn) {
        deleteListingBtn.addEventListener('click', async () => {
            const result = await Swal.fire({
                title: 'Delete this Listing?',
                text: "This will permanently remove your hotel from WanderLust. You cannot undo this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ff385c',
                cancelButtonColor: '#222',
                confirmButtonText: 'Yes, delete it',
                background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#1e1e1e' : '#fff',
                color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#fff' : '#222',
                customClass: {
                    popup: 'rounded-4 border-0 shadow-lg',
                    confirmButton: 'rounded-pill px-4',
                    cancelButton: 'rounded-pill px-4'
                }
            });

            if (result.isConfirmed) {
                document.getElementById('deleteListingForm').submit();
            }
        });
    }

    // Delete Review Confirmation
    document.querySelectorAll('.delete-review-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const result = await Swal.fire({
                title: 'Delete your review?',
                text: "Your feedback will be removed. This cannot be undone.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ff385c',
                cancelButtonColor: '#222',
                confirmButtonText: 'Yes, delete it',
                background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#1e1e1e' : '#fff',
                color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#fff' : '#222',
                customClass: {
                    popup: 'rounded-4 border-0 shadow-lg',
                    confirmButton: 'rounded-pill px-4',
                    cancelButton: 'rounded-pill px-4'
                }
            });

            if (result.isConfirmed) {
                btn.closest('form').submit();
            }
        });
    });
})();


</script>

