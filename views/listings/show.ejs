                <% } %>
                <% if (currUser && review.author && review.author._id.equals(currUser._id)) { %>
                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mt-2 delete-review-form">
                      <button type="button" class="btn btn-sm text-danger fw-bold px-0 delete-review-btn" style="background: none; border: none; font-size: 0.8rem;">
                          <i class="fa-solid fa-trash-can me-1"></i>Delete
