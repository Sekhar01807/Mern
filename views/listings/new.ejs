<% layout("/layouts/boilerplate") %>

<div class="row mt-4 mb-5">
    <div class="col-12 col-md-8 offset-md-2">
        <%- include("../includes/flash.ejs") %>
        <div class="card shadow border-0 rounded-4">
            <div class="card-body p-4 p-md-5">
                <h3 class="mb-4 fw-bold" style="color: #ff385c;"><i class="fa-solid fa-plus-circle me-2"></i>Create a New Listing</h3>
                <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
    <div class="mb-3">  
        <label for="title" class="form-label"> Title</label>
        <input type="text" name="listing[title]" placeholder="Enter Title " class="form-control" required> 
           <div class="valid-feedback"> Great Title</div>
    </div>
    <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea type="text" name="listing[description]" class="form-control" required ></textarea>
          <div class="invalid-feedback"> Description is Empty</div>
    </div>
    <div class="mb-3">
        <label for="image" class="form-label fw-bold">Main Listing Image</label>
        <input type="file" id="listingImage" name="listing[image]" class="form-control" accept=".png, .jpg, .jpeg, .webp, image/*" required >
        <div class="invalid-feedback">Main image is required</div>
        <img id="listing-preview" src="" style="display: none; width: 100%; height: 250px; object-fit: cover; margin-top: 15px;" class="rounded shadow-sm border">
    </div>
    <div class="mb-3">
        <label for="images" class="form-label fw-bold">Additional Photos (Optional)</label>
        <input type="file" name="listing[images]" class="form-control" accept=".png, .jpg, .jpeg, .webp, image/*" multiple>
        <p class="text-muted small mt-1"><i class="fa-solid fa-circle-info me-1"></i>You can select up to 6 extra photos of your place.</p>
    </div>
    <div class="row ">
    <div class="mb-3 col-md-4">
        <label for="price" class="form-label">Price</label>
        <input name="listing[price]" placeholder="Enter Price"  class="form-control" required> 
         <div class="invalid-feedback">Price Field is Empty</div>
    </div>    
    <div class="mb-3 col-md-4"> 
        <label for="Country" class="form-label">Country</label>
        <input type="text" name="listing[country]" placeholder="Enter country" class="form-control" required > 
         <div class="invalid-feedback"> Country is Required !</div>
    </div>
    <div class="mb-3 col-md-4">
        <label for="category" class="form-label">Category</label>
        <select name="listing[category]" class="form-select" required>
            <% for(let cat of categories) { %>
                <option value="<%= cat %>"><%= cat.replace(/_/g,' ').replace(/\b\w/g, c => c.toUpperCase()) %></option>
            <% } %>
        </select>
        <div class="invalid-feedback">Select a category</div>
    </div>
    </div>
        <div class="mb-3">  
        <label for="location" class="form-label">Location</label>
        <input type="text" name="listing[location]" placeholder="Enter location"  class="form-control" required> 
         <div class="invalid-feedback">Location is Required </div>
    </div>    
        <button class="btn btn-danger w-100 py-2 fs-5 fw-bold rounded-3" style="background-color: #ff385c; border: none; transition: 0.2s;">
            <i class="fa-solid fa-cloud-arrow-up me-2"></i>Add Listing
        </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
// Setup Cropper for New Listing Image (Aspect ratio 16:9)
document.addEventListener("DOMContentLoaded", () => {
    if (typeof setupImageCropper === 'function') {
        setupImageCropper('listingImage', 'listing-preview', 16/9);
    }
});
</script>
