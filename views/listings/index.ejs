<% layout("/layouts/boilerplate") %>
<body>
    <%- include("../includes/flash.ejs") %>
    <div class="filters-main-container d-flex align-items-center mt-3 mb-4">
        <div id="filter" class="d-flex flex-nowrap overflow-auto" style="scrollbar-width: none; -ms-overflow-style: none;">
            <a href="/listings" class="filter-link">
                <div class="filter <%= category === 'all' ? 'filter-active' : '' %>">
                    <div><i class="fa-solid fa-border-all"></i></div>
                    <p>All</p>
                </div>
            </a>
            <a href="/listings?category=trending" class="filter-link">
                <div class="filter <%= category === 'trending' ? 'filter-active' : '' %>">
                    <div><i class="fa-solid fa-fire"></i></div>
                    <p>Trending</p>
                </div>
            </a>
            <a href="/listings?category=rooms" class="filter-link">
                <div class="filter <%= category === 'rooms' ? 'filter-active' : '' %>">
                    <div><i class="fa-solid fa-bed"></i></div>
                    <p>Rooms</p>
                </div>
            </a>
            <a href="/listings?category=cities" class="filter-link">
                <div class="filter <%= category === 'cities' ? 'filter-active' : '' %>">
                    <div><i class="fa-solid fa-city"></i></div>
                    <p>Cities</p>
                </div>
            </a>
            <a href="/listings?category=pools" class="filter-link">
                <div class="filter <%= category === 'pools' ? 'filter-active' : '' %>">
                    <div><i class="fa-solid fa-person-swimming"></i></div>
                    <p>Pools</p>
                </div>
            </a>
            <a href="/listings?category=hills" class="filter-link">
                <div class="filter <%= category === 'hills' ? 'filter-active' : '' %>">
                    <div><i class="fa-solid fa-mountain"></i></div>
                    <p>Hills</p>
                </div>
            </a>
            <a href="/listings?category=star_hotels" class="filter-link">
                <div class="filter <%= category === 'star_hotels' ? 'filter-active' : '' %>">
                    <div><i class="fa-solid fa-star"></i></div>
                    <p>Hotels</p>
                </div>
            </a>
            <a href="/listings?category=private_house" class="filter-link">
                <div class="filter <%= category === 'private_house' ? 'filter-active' : '' %>">
                    <div><i class="fa-solid fa-house"></i></div>
                    <p>Private</p>
                </div>
            </a>
            <a href="/listings?category=best_deals" class="filter-link">
                <div class="filter <%= category === 'best_deals' ? 'filter-active' : '' %>">
                    <div><i class="fa-solid fa-tag"></i></div>
                    <p>Deals</p>
                </div>
            </a>
            <a href="/listings?category=premium" class="filter-link">
                <div class="filter <%= category === 'premium' ? 'filter-active' : '' %>">
                    <div><i class="fa-solid fa-crown"></i></div>
                    <p>Premium</p>
                </div>
            </a>
            <a href="/listings?category=nearby" class="filter-link">
                <div class="filter <%= category === 'nearby' ? 'filter-active' : '' %>">
                    <div><i class="fa-solid fa-location-dot"></i></div>
                    <p>Nearby</p>
                </div>
            </a>
            <a href="/wishlist" class="filter-link">
                <div class="filter <%= category === 'wishlist' ? 'filter-active' : '' %>">
                    <div><i class="fa-solid fa-heart"></i></div>
                    <p>Wishlist</p>
                </div>
            </a>
            <a href="/listings?category=others" class="filter-link">
                <div class="filter <%= category === 'others' ? 'filter-active' : '' %>">
                    <div><i class="fa-solid fa-ellipsis"></i></div>
                    <p>Others</p>
                </div>
            </a>
        </div>

        <div class="tax-toggle ms-auto d-none d-md-block">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label fw-bold" for="switchCheckDefault" style="white-space: nowrap;">Display total before taxes</label>
            </div>
        </div>
    </div>

    <% if(search && search.trim()) { %>
        <div class="mt-3 mb-2 d-flex align-items-center">
            <span class="text-muted">Results for "<strong><%= search %></strong>" — <%= allListings.length %> found</span>
            <a href="/listings" class="btn btn-sm btn-outline-secondary ms-3">Clear Search</a>
        </div>
    <% } %>

    <% if(allListings.length === 0) { %>
        <div class="text-center mt-5 mb-5">
            <i class="fa-solid fa-magnifying-glass" style="font-size:3rem;color:#ccc;"></i>
            <h4 class="mt-3 text-muted">No listings found</h4>
            <p class="text-muted">Try a different search or category</p>
            <a href="/listings" class="btn btn-outline-danger">View All Listings</a>
        </div>
    <% } else { %>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% for(let listing of allListings){ %>
            <div class="col mb-4">
            <div class="card listing-card shadow-sm border-0 rounded-4 overflow-hidden h-100">
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="listing-img-container" style="overflow: hidden; border-radius: 1rem; position: relative;">
                        <img src="<%= listing.image.url %>" class="card-img-top" alt="image" style="height:20rem; border-radius: 1rem !important;">
                        <div class="card-img-overlay"></div>
                        <!-- Book Now overlay -->
                        <div class="book-now-overlay">
                            <span class="book-now-text"><i class="fa-solid fa-calendar-check me-2"></i>Book Now</span>
                        </div>
                    </div>
                </a>
                
                <% if(typeof currUser !== 'undefined' && currUser) { %>
                <div class="wishlist-btn-form">
                    <button type="button" class="wishlist-btn" title="Toggle Wishlist" data-listing-id="<%= listing._id %>">
                        <% if(currUser.wishlist && currUser.wishlist.map(w=>w.toString()).includes(listing._id.toString())) { %>
                            <i class="fa-solid fa-heart" style="color:crimson;"></i>
                        <% } else { %>
                            <i class="fa-regular fa-heart"></i>
                        <% } %>
                    </button>
                </div>
                <% } %>
                
                <a href="/listings/<%= listing._id %>" class="listing-link" style="text-decoration:none; color:inherit;">
                    <div class="card-body">
                        <h4 class="card-title"><%= listing.title %></h4>
                        <p class="card-text mb-1 text-muted"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></p>
                        <p class="card-text mb-1"><%= listing.description %></p>
                        <p class="card-text">
                            <strong>&#8377 <%= listing.price ? listing.price.toLocaleString() : "N/A" %></strong>/Night
                            <i class="tax-info text-muted" style="font-size: 0.9em;">  &nbsp; +18% GST</i>
                        </p>
                    </div>
                </a>
            </div>
            </div>
        <% } %>
    </div>
    <% } %>
</body>

<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for (info of taxInfo) {
            if (info.style.display != "inline") {
                info.style.display = "inline";
            } else {
                info.style.display = "none";
            }
        }
    });

    // Wishlist AJAX Toggle (with SweetAlert2 Toasts)
    const Toast = Swal.mixin({
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 2500,
        timerProgressBar: true,
        background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#1e1e1e' : '#fff',
        color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#fff' : '#222',
        didOpen: (toast) => {
            toast.addEventListener('mouseenter', Swal.stopTimer)
            toast.addEventListener('mouseleave', Swal.resumeTimer)
        }
    });

    document.querySelectorAll('.wishlist-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            e.preventDefault();
            e.stopPropagation();
            const listingId = btn.dataset.listingId;
            try {
                const res = await fetch(`/wishlist/${listingId}`, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });
                if (res.redirected) {
                    window.location.href = res.url;
                    return;
                }
                if (res.ok) {
                    const data = await res.json();
                    const icon = btn.querySelector('i');
                    if (data.wishlisted) {
                        icon.className = 'fa-solid fa-heart';
                        icon.style.color = 'crimson';
                        btn.style.transform = 'scale(1.3)';
                        setTimeout(() => btn.style.transform = '', 200);
                        Toast.fire({
                            icon: 'success',
                            title: 'Added to Wishlist'
                        });
                    } else {
                        icon.className = 'fa-regular fa-heart';
                        icon.style.color = '';
                        Toast.fire({
                            icon: 'info',
                            title: 'Removed from Wishlist'
                        });
                    }
                }
            } catch (err) {
                console.error('Wishlist toggle failed', err);
                Toast.fire({
                    icon: 'error',
                    title: 'Something went wrong'
                });
            }
        });
    });
</script>